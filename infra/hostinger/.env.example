# Transmuter Hostinger VPS environment template.
# Copy to infra/hostinger/.env, fill in real values, and keep that file uncommitted.
#
# The deploy script defaults to Hostinger VPS Docker Manager API mode. The
# legacy staged bundle mode is available with HOSTINGER_DEPLOY_MODE=local.

# ── Hostinger remote deployment ───────────────────────────────────────────
# Default deploy mode is remote Hostinger VPS Docker Manager API. Dev and
# production are separate Docker Compose projects on the same VPS with different
# images, bind ports, schemas, and Traefik hostnames.
# HOSTINGER_DEPLOY_MODE=api
# HOSTINGER_API_BASE_URL=https://developers.hostinger.com
# Prefer exporting HOSTINGER_API_TOKEN or HAPI_API_TOKEN in the operator shell.
# This ignored env file may hold it for a single workstation, but never commit it.
# HOSTINGER_API_TOKEN=replace-with-hostinger-api-token
# HOSTINGER_VPS_ID=replace-with-hostinger-vps-id

# API mode is image-only. Use registry images that the VPS can pull. If the
# registry is private, either preconfigure Docker auth on the VPS or use
# HOSTINGER_BUILD_AND_PUSH_IMAGES with registry credentials below.
TRANSMUTER_COMPOSE_PROJECT=transmuter-hostinger
TRANSMUTER_API_IMAGE=transmuter-api:hostinger
TRANSMUTER_WEB_IMAGE=transmuter-web:hostinger
# Set to never when using images already built on the VPS. Use missing/always
# for registry-backed images.
# TRANSMUTER_IMAGE_PULL_POLICY=never
# HOSTINGER_BUILD_AND_PUSH_IMAGES=0
# HOSTINGER_IMAGE_PLATFORM=linux/amd64
# HOSTINGER_DOCKER_REGISTRY=ghcr.io
# HOSTINGER_DOCKER_USERNAME=replace-with-registry-username
# HOSTINGER_DOCKER_PASSWORD=replace-with-registry-token
# Set only when using VPS-local image tags such as transmuter-api:hostinger.
# HOSTINGER_ALLOW_LOCAL_IMAGE_TAGS=1

# ── Legacy Hostinger VPS-local deployment script ──────────────────────────
# Use HOSTINGER_DEPLOY_MODE=local only when running this command directly on the
# Hostinger VPS. The API mode does not use SSH, rsync, or a local /docker path.
HOSTINGER_SSH_HOST=srv1695814.hstgr.cloud
HOSTINGER_PUBLIC_IP=76.13.208.106
HOSTINGER_SSH_USER=root
HOSTINGER_SSH_PORT=22
HOSTINGER_DEPLOY_DIR=/docker/transmuter

# Set to 1 only when you want infra/hostinger/deploy.sh to run the
# schema migration script on the VPS before recreating containers.
RUN_DB_SCHEMA_MIGRATION=0

# ── Public runtime URLs ───────────────────────────────────────────────────
APP_PUBLIC_URL=https://transmuter.ishirock.tech
TRANSMUTER_API_URL=/api
TRANSMUTER_ENVIRONMENT=production

# ── Traefik routing ───────────────────────────────────────────────────────
# Traefik runs on the host network. The web container binds only to localhost
# port 4301 on the VPS, and Traefik routes this hostname to the Docker service.
# /api is proxied by the web nginx container to http://api:8001 on the private
# app network.
TRAEFIK_HOSTNAME=transmuter.ishirock.tech
TRAEFIK_HTTP_ENTRYPOINT=web
TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRANSMUTER_WEB_BIND=127.0.0.1:4301

# ── Supabase target switch ────────────────────────────────────────────────
# Change SUPABASE_TARGET to cloud and restart the API/container to roll back to
# Supabase Cloud. Keep local as the Hostinger primary runtime target.
SUPABASE_TARGET=local

SUPABASE_LOCAL_URL=https://supabase.ishirock.tech
SUPABASE_LOCAL_ANON_KEY=replace-with-local-supabase-anon-key
SUPABASE_LOCAL_SERVICE_KEY=replace-with-local-supabase-service-role-key

# API/worker direct PostgreSQL connection for local Supabase. Keep search_path on
# transmuter first because app tables live outside the Supabase-managed schemas.
# If the Supabase Postgres port is published on the VPS host, host.docker.internal
# works from the Transmuter containers because the compose bundle adds
# host-gateway resolution.
DATABASE_LOCAL_URL=postgresql://postgres:***@host.docker.internal:5432/postgres?options=-csearch_path%3Dtransmuter,public,extensions
SUPABASE_SCHEMA=transmuter

# Cloud fallback/demo target.
SUPABASE_CLOUD_URL=https://kdtytqnnxxwdasaqwzlg.supabase.co
SUPABASE_CLOUD_ANON_KEY=replace-with-cloud-supabase-anon-key
SUPABASE_CLOUD_SERVICE_KEY=replace-with-cloud-supabase-service-role-key
DATABASE_CLOUD_URL=postgresql://postgres:***@db.cloud-project-ref.supabase.co:5432/postgres

# Optional legacy direct/fallback values. Leave blank when target-specific values
# above are configured.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# Local Supabase REST must expose transmuter first for unqualified .table(...) calls.
PGRST_DB_SCHEMAS=transmuter,public,graphql_public
PGRST_DB_EXTRA_SEARCH_PATH=transmuter,public,extensions

# RLS verification helper schema for apps/api/scripts/verify_rls.py and live RLS tests.
DB_SCHEMA=transmuter

# Used only by infra/hostinger/migrate_supabase_schema_to_transmuter.sh.
SOURCE_DATABASE_URL=postgresql://postgres:***@db.cloud-project-ref.supabase.co:5432/postgres?sslmode=require
TARGET_DATABASE_URL=postgresql://postgres:***@127.0.0.1:5432/postgres
SOURCE_SCHEMA=public
TARGET_SCHEMA=transmuter
RESET_TARGET_SCHEMA=false

# ── Authentication ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── LLM / observability ───────────────────────────────────────────────────
AI_ENABLED=true
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Billing / payments ───────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=replace-with-stripe-secret
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_TEAM_MONTHLY=replace-with-price-id
STRIPE_PRICE_TEAM_ANNUAL=replace-with-price-id
STRIPE_PRICE_BUSINESS_MONTHLY=replace-with-price-id
STRIPE_PRICE_BUSINESS_ANNUAL=replace-with-price-id
ENCRYPTION_KEY=replace-with-base64-32-byte-fernet-key

# ── SaaS operator access ─────────────────────────────────────────────────
PLATFORM_ADMIN_EMAILS=venkatesh@ishirock.com
PLATFORM_ADMIN_BOOTSTRAP_ENABLED=true
PLATFORM_ADMIN_BOOTSTRAP_EMAIL=venkatesh@ishirock.com
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=
# One-time only: used by scripts/rotate_platform_admin_email.py.
PLATFORM_ADMIN_PREVIOUS_EMAIL=

# ── Minimal local bootstrap ───────────────────────────────────────────────
# Used by apps/api/scripts/bootstrap_hostinger_local.py. These create only the
# platform/admin Auth shell, one blank admin tenant, subscription shell, financial
# configuration, and gate criteria. They do not seed operational portfolio data.
HOSTINGER_PLATFORM_ADMIN_EMAIL=venkatesh@ishirock.com
HOSTINGER_TENANT_ADMIN_EMAIL=admin@ishirock.dev
HOSTINGER_TENANT_ADMIN_NAME='Tenant Admin'
HOSTINGER_BOOTSTRAP_TENANT_NAME='Transmuter Platform Admin'
HOSTINGER_BOOTSTRAP_TENANT_SLUG=transmuter-admin
HOSTINGER_BOOTSTRAP_PLANNED_USERS=1
HOSTINGER_ADMIN_PASSWORD=replace-with-temporary-bootstrap-password

# ── Optional notifications ────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
