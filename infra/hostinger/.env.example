# Transmuter Hostinger VPS environment template.
# Copy to infra/hostinger/.env, fill in real values, and keep that file uncommitted.

# ── Hostinger deployment script ───────────────────────────────────────────
HOSTINGER_SSH_HOST=srv1695814.hstgr.cloud
HOSTINGER_PUBLIC_IP=76.13.208.106
HOSTINGER_SSH_USER=root
HOSTINGER_SSH_PORT=22
HOSTINGER_DEPLOY_DIR=/opt/transmuter

# Set to 1 only when you want infra/hostinger/deploy.sh to run the
# schema migration script on the VPS before recreating containers.
RUN_DB_SCHEMA_MIGRATION=0

# ── Public runtime URLs ───────────────────────────────────────────────────
APP_PUBLIC_URL=https://transmuter.ishirock.tech
SUPABASE_URL=https://supabase.ishirock.tech
TRANSMUTER_API_URL=/api
TRANSMUTER_ENVIRONMENT=production

# ── Traefik routing ───────────────────────────────────────────────────────
# Traefik runs on the host network. The web container binds only to localhost
# port 4301 on the VPS, and Traefik routes this hostname to the Docker service.
# /api is proxied by the web nginx container to http://api:8001 on the private
# app network.
TRAEFIK_HOSTNAME=transmuter.ishirock.tech
TRAEFIK_HTTP_ENTRYPOINT=web
TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRANSMUTER_WEB_BIND=127.0.0.1:4301

# ── Supabase / database ───────────────────────────────────────────────────
SUPABASE_ANON_KEY=replace-with-local-supabase-anon-key
SUPABASE_SERVICE_KEY=replace-with-local-supabase-service-role-key

# API/worker direct PostgreSQL connection. Keep search_path on transmuter first.
# If the Supabase Postgres port is published on the VPS host, host.docker.internal
# works from the Transmuter containers because infra/hostinger/docker-compose.yml adds
# host-gateway resolution.
DATABASE_URL=postgresql://postgres:replace-with-local-db-password@host.docker.internal:5432/postgres?options=-csearch_path%3Dtransmuter,public

# Used only by infra/hostinger/migrate_supabase_schema_to_transmuter.sh.
SOURCE_DATABASE_URL=postgresql://postgres:replace-with-cloud-db-password@db.cloud-project-ref.supabase.co:5432/postgres?sslmode=require
TARGET_DATABASE_URL=postgresql://postgres:replace-with-local-db-password@127.0.0.1:5432/postgres
SOURCE_SCHEMA=public
TARGET_SCHEMA=transmuter
RESET_TARGET_SCHEMA=false

# ── Authentication ────────────────────────────────────────────────────────
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── LLM / observability ───────────────────────────────────────────────────
AI_ENABLED=true
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Billing / payments ───────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=replace-with-stripe-secret
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
STRIPE_PRICE_TEAM_MONTHLY=replace-with-price-id
STRIPE_PRICE_TEAM_ANNUAL=replace-with-price-id
STRIPE_PRICE_BUSINESS_MONTHLY=replace-with-price-id
STRIPE_PRICE_BUSINESS_ANNUAL=replace-with-price-id
ENCRYPTION_KEY=replace-with-base64-32-byte-fernet-key

# ── SaaS operator access ─────────────────────────────────────────────────
PLATFORM_ADMIN_EMAILS=operator@example.com

# ── Optional notifications ────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
