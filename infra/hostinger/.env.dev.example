# Transmuter Hostinger DEV environment template.
# Copy to infra/hostinger/.env.dev, fill in real values, and keep .env.dev uncommitted.
#
# The dev stack is intentionally separate from production:
# - bundle root: /docker/transmuter-dev
# - compose project: transmuter-dev-hostinger
# - images: registry-backed dev API/web image tags
# - host bind: 127.0.0.1:4302
# - public hostname: https://transmuter-dev.ishirock.tech
# - Supabase schema: transmuter_dev

# Hostinger remote deployment
# HOSTINGER_DEPLOY_MODE=api
# HOSTINGER_API_BASE_URL=https://developers.hostinger.com
# Prefer exporting HOSTINGER_API_TOKEN or HAPI_API_TOKEN in the operator shell.
# This ignored env file may hold it for a single workstation, but never commit it.
# HOSTINGER_API_TOKEN=replace-with-hostinger-api-token
# HOSTINGER_VPS_ID=replace-with-hostinger-vps-id

# API mode is image-only. Dev and production share the same VPS but use different
# Compose projects, image tags, bind ports, Supabase schemas, and hostnames.
HOSTINGER_DEPLOY_DIR=/docker/transmuter-dev
TRANSMUTER_COMPOSE_PROJECT=transmuter-dev-hostinger
HOSTINGER_STOP_PROJECTS=transmuter-dev-hostinger
TRANSMUTER_API_IMAGE=transmuter-api:hostinger-dev
TRANSMUTER_WEB_IMAGE=transmuter-web:hostinger-dev
# Set to never when using images already built on the VPS. Use missing/always
# for registry-backed images.
# TRANSMUTER_IMAGE_PULL_POLICY=never
# HOSTINGER_BUILD_AND_PUSH_IMAGES=0
# HOSTINGER_IMAGE_PLATFORM=linux/amd64
# HOSTINGER_DOCKER_REGISTRY=ghcr.io
# HOSTINGER_DOCKER_USERNAME=replace-with-registry-username
# HOSTINGER_DOCKER_PASSWORD=replace-with-registry-token
# Set only when using VPS-local image tags such as transmuter-api:hostinger-dev.
# HOSTINGER_ALLOW_LOCAL_IMAGE_TAGS=1
RUN_DB_SCHEMA_MIGRATION=0

# Public runtime URLs
APP_PUBLIC_URL=https://transmuter-dev.ishirock.tech
TRANSMUTER_API_URL=/api
TRANSMUTER_ENVIRONMENT=development

# Traefik routing
TRAEFIK_HOSTNAME=transmuter-dev.ishirock.tech
TRAEFIK_ROUTER_NAME=transmuter-dev-web
TRAEFIK_SERVICE_NAME=transmuter-dev-web
TRAEFIK_HTTP_ENTRYPOINT=web
TRAEFIK_HTTPS_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt
TRANSMUTER_WEB_BIND=127.0.0.1:4302

# Supabase local target with dev schema
SUPABASE_TARGET=local
SUPABASE_SCHEMA=transmuter_dev
DB_SCHEMA=transmuter_dev

SUPABASE_LOCAL_URL=https://supabase.ishirock.tech
SUPABASE_LOCAL_ANON_KEY=replace-with-local-supabase-anon-key
SUPABASE_LOCAL_SERVICE_KEY=replace-with-local-supabase-service-role-key
DATABASE_LOCAL_URL=postgresql://postgres:***@host.docker.internal:5432/postgres?options=-csearch_path%3Dtransmuter_dev,public,extensions

# Local Supabase REST must expose transmuter_dev before transmuter for this
# dev app. Update the Supabase REST container configuration separately.
PGRST_DB_SCHEMAS=transmuter_dev,transmuter,public,graphql_public
PGRST_DB_EXTRA_SEARCH_PATH=transmuter_dev,transmuter,public,extensions

# Cloud fallback/demo target. Populate only if dev needs cloud fallback.
SUPABASE_CLOUD_URL=
SUPABASE_CLOUD_ANON_KEY=
SUPABASE_CLOUD_SERVICE_KEY=
DATABASE_CLOUD_URL=

# Optional legacy direct/fallback values. Leave blank when target-specific values
# above are configured.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# Schema clone helper
# Used by infra/hostinger/clone_schema_to_dev.sh.
DEV_CLONE_DATABASE_URL=postgresql://postgres:***@127.0.0.1:5432/postgres
SOURCE_SCHEMA=transmuter
TARGET_SCHEMA=transmuter_dev
RESET_TARGET_SCHEMA=false
# Set this when DEV_CLONE_DATABASE_URL uses a Supabase Compose service hostname
# such as db and local pg_dump/psql are not installed on the host.
POSTGRES_DOCKER_NETWORK=supabase-aethos_default

# Authentication
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# LLM / observability
AI_ENABLED=true
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Billing / payments
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
ENCRYPTION_KEY=

# SaaS operator access
PLATFORM_ADMIN_EMAILS=venkatesh@ishirock.com
PLATFORM_ADMIN_BOOTSTRAP_ENABLED=true
PLATFORM_ADMIN_BOOTSTRAP_EMAIL=venkatesh@ishirock.com
PLATFORM_ADMIN_BOOTSTRAP_PASSWORD=
# One-time only: used by scripts/rotate_platform_admin_email.py.
PLATFORM_ADMIN_PREVIOUS_EMAIL=

# Optional notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=
