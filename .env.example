# Transmuter Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://kdtytqnnxxwdasaqwzlg.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# PostgreSQL direct connection (for Procrastinate background worker)
DATABASE_URL=postgresql://postgres:[password]@db.kdtytqnnxxwdasaqwzlg.supabase.co:5432/postgres

# ── Notifications ────────────────────────────────────────────────────────
# Optional. Without these, status nudges are logged and remain queued.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Transmuter <notifications@example.com>"

# ── Authentication ────────────────────────────────────────────────────────
# Must be at least 32 characters. Never use a default/guessable value.
JWT_SECRET=replace-with-32-char-random-secret-here

# ── LLM Gateway ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ── Observability ─────────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Feature Flags ────────────────────────────────────────────────────────
AI_ENABLED=true

# ── Billing / Payments ───────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...
ENCRYPTION_KEY=base64-32-byte-fernet-key

# ── SaaS Operator Access ─────────────────────────────────────────────────
# Comma-separated Supabase Auth emails allowed to access /platform.
PLATFORM_ADMIN_EMAILS=operator@example.com
