# Transmuter Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# ── Supabase target switch ────────────────────────────────────────────────
# Use cloud for Supabase Cloud, local for the Hostinger self-hosted Supabase.
# Target-specific values are preferred. Legacy direct values below are fallback
# compatibility values when the selected target-specific value is absent.
SUPABASE_TARGET=cloud

SUPABASE_CLOUD_URL=https://kdtytqnnxxwdasaqwzlg.supabase.co
SUPABASE_CLOUD_ANON_KEY=your-cloud-supabase-anon-key
SUPABASE_CLOUD_SERVICE_KEY=your-cloud-supabase-service-role-key
DATABASE_CLOUD_URL=postgresql://postgres:[password]@db.kdtytqnnxxwdasaqwzlg.supabase.co:5432/postgres

SUPABASE_LOCAL_URL=https://supabase.ishirock.tech
SUPABASE_LOCAL_ANON_KEY=your-local-supabase-anon-key
SUPABASE_LOCAL_SERVICE_KEY=your-local-supabase-service-role-key
DATABASE_LOCAL_URL=postgresql://postgres:[local-password]@host.docker.internal:5432/postgres?options=-csearch_path%3Dtransmuter,public,extensions

# Optional legacy direct/fallback values.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# RLS verification helper schema. Use transmuter when validating Hostinger local
# Supabase metadata/behavior.
DB_SCHEMA=public

# ── Notifications ────────────────────────────────────────────────────────
# Optional. Without these, status nudges are logged and remain queued.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Transmuter <notifications@example.com>"

# ── Authentication ────────────────────────────────────────────────────────
# Must be at least 32 characters. Never use a default/guessable value.
JWT_SECRET=replace-with-32-char-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ── LLM Gateway ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# ── Observability ─────────────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App Runtime ───────────────────────────────────────────────────────────
APP_NAME=Transmuter API
VERSION=0.1.0
DEBUG=false
APP_PUBLIC_URL=http://localhost:4300

# ── Meeting Integrations ─────────────────────────────────────────────────
# Optional. Enables tenant admins to connect Microsoft 365 organizer accounts
# for Teams calendar invites, join links, and transcript sync.
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_TENANT_ID=common
MICROSOFT_GRAPH_REDIRECT_URI=
MICROSOFT_GRAPH_SCOPES="offline_access User.Read Calendars.ReadWrite OnlineMeetings.Read OnlineMeetingTranscript.Read.All"
RECALL_MEETING_BOT_ENABLED=false
FIREFLIES_MEETING_BOT_ENABLED=false

# ── Feature Flags ────────────────────────────────────────────────────────
AI_ENABLED=true

# ── Billing / Payments ───────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...
ENCRYPTION_KEY=base64-32-byte-fernet-key

# ── SaaS Operator Access ─────────────────────────────────────────────────
# Comma-separated Supabase Auth emails allowed to access /platform.
PLATFORM_ADMIN_EMAILS=operator@example.com

# ── Frontend Runtime ─────────────────────────────────────────────────────
# Used by the production web container to point Angular at the API.
TRANSMUTER_API_URL=http://localhost:8001
